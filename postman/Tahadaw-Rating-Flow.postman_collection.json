{
  "info": {
    "name": "Tahadaw - Product Rating Flow",
    "description": "End-to-end flow that exercises the product search / rating storage path.\n\nRun the requests in order (top to bottom) using the Collection Runner, or send them one by one. Each step stores the IDs it creates into collection variables, so later steps pick them up automatically.\n\nFlow:\n1. Create User\n2. Find User Id (capture {{userId}})\n3. Add Recipient (with interests so the AI has context)\n4. Find Recipient Id (capture {{recipientId}})\n5. Create Gift Plan\n6. Find Gift Plan Id (capture {{giftPlanId}})\n7. Generate AI Gift Recommendations (capture {{recommendationId}})\n8. Select a Recommendation\n9. Search Products  <-- this is the step that stores SelectedProduct.rating\n10. (optional) it also asserts at least one stored product has a non-null rating\n",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8080", "type": "string" },
    { "key": "username", "value": "", "type": "string" },
    { "key": "recipientName", "value": "", "type": "string" },
    { "key": "userId", "value": "", "type": "string" },
    { "key": "recipientId", "value": "", "type": "string" },
    { "key": "giftPlanId", "value": "", "type": "string" },
    { "key": "recommendationId", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "1. Create User",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// Generate unique-ish username/email so re-runs don't hit unique constraints.",
              "const stamp = Date.now().toString().slice(-7);",
              "pm.collectionVariables.set('username', 'tester' + stamp);",
              "pm.collectionVariables.set('recipientName', 'Recipient ' + stamp);",
              "pm.collectionVariables.set('email', 'tester' + stamp + '@example.com');"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('User created (200)', () => pm.response.code === 200);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{base_url}}/api/v1/users/add", "host": ["{{base_url}}"], "path": ["api", "v1", "users", "add"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"password123\",\n  \"fullName\": \"Test User\",\n  \"email\": \"{{email}}\",\n  \"phoneNumber\": \"0512345678\"\n}"
        }
      }
    },
    {
      "name": "2. Find User Id",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const users = pm.response.json();",
              "const wanted = pm.collectionVariables.get('username');",
              "const me = (Array.isArray(users) ? users : []).find(u => u.username === wanted);",
              "pm.test('Found created user', () => pm.expect(me, 'user with username ' + wanted).to.be.an('object'));",
              "if (me) { pm.collectionVariables.set('userId', me.id); console.log('userId =', me.id); }"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "{{base_url}}/api/v1/users/get", "host": ["{{base_url}}"], "path": ["api", "v1", "users", "get"] }
      }
    },
    {
      "name": "3. Add Recipient",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Recipient added (200)', () => pm.response.code === 200);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": {
          "raw": "{{base_url}}/api/v1/recipients/add/{{userId}}",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "recipients", "add", "{{userId}}"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"{{recipientName}}\",\n  \"relationship\": \"brother\",\n  \"age\": 25,\n  \"gender\": \"male\",\n  \"interests\": \"smartphones, gadgets, photography\",\n  \"hobbies\": \"gaming, tech reviews\",\n  \"favoriteColors\": \"black, blue\",\n  \"favoriteBrands\": \"Apple, Samsung\",\n  \"personalityStyle\": \"practical\"\n}"
        }
      }
    },
    {
      "name": "4. Find Recipient Id",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const recipients = pm.response.json();",
              "const wanted = pm.collectionVariables.get('recipientName');",
              "const list = Array.isArray(recipients) ? recipients : [];",
              "const mine = list.filter(r => r.name === wanted);",
              "const r = mine.length ? mine[mine.length - 1] : null;",
              "pm.test('Found created recipient', () => pm.expect(r, 'recipient named ' + wanted).to.be.an('object'));",
              "if (r) { pm.collectionVariables.set('recipientId', r.id); console.log('recipientId =', r.id); }"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "{{base_url}}/api/v1/recipients/get", "host": ["{{base_url}}"], "path": ["api", "v1", "recipients", "get"] }
      }
    },
    {
      "name": "5. Create Gift Plan",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Gift plan created (200)', () => pm.response.code === 200);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": {
          "raw": "{{base_url}}/api/v1/gift-plans/create/{{userId}}/{{recipientId}}",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "gift-plans", "create", "{{userId}}", "{{recipientId}}"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"occasionType\": \"birthday\",\n  \"occasionDate\": \"2026-12-31\",\n  \"budgetMinor\": 300000,\n  \"currency\": \"SAR\",\n  \"preferredGiftStyle\": \"tech\",\n  \"language\": \"ar\"\n}"
        }
      }
    },
    {
      "name": "6. Find Gift Plan Id",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const plans = pm.response.json();",
              "const list = Array.isArray(plans) ? plans : [];",
              "pm.test('User has at least one gift plan', () => pm.expect(list.length).to.be.above(0));",
              "if (list.length) {",
              "  const last = list[list.length - 1];",
              "  pm.collectionVariables.set('giftPlanId', last.id);",
              "  console.log('giftPlanId =', last.id);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/v1/gift-plans/get-my-plans/{{userId}}",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "gift-plans", "get-my-plans", "{{userId}}"]
        }
      }
    },
    {
      "name": "7. Generate AI Gift Recommendations",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Recommendations generated (200)', () => pm.response.code === 200);",
              "const recs = pm.response.json();",
              "const list = Array.isArray(recs) ? recs : [];",
              "pm.test('At least one recommendation returned', () => pm.expect(list.length).to.be.above(0));",
              "if (list.length) {",
              "  pm.collectionVariables.set('recommendationId', list[0].id);",
              "  console.log('recommendationId =', list[0].id, 'productName =', list[0].productName);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/v1/gift-plans/get-rec/{{userId}}/{{giftPlanId}}",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "gift-plans", "get-rec", "{{userId}}", "{{giftPlanId}}"]
        }
      }
    },
    {
      "name": "8. Select a Recommendation",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Recommendation selected (200)', () => pm.response.code === 200);"
            ]
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/v1/gift-plans/select-Recomendation/{{userId}}/{{recommendationId}}",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "gift-plans", "select-Recomendation", "{{userId}}", "{{recommendationId}}"]
        }
      }
    },
    {
      "name": "9. Search Products (stores rating)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Product search ok (200)', () => pm.response.code === 200);",
              "const products = pm.response.json();",
              "const list = Array.isArray(products) ? products : [];",
              "pm.test('At least one product stored', () => pm.expect(list.length).to.be.above(0));",
              "console.log('Stored products and their ratings:');",
              "list.forEach((p, i) => console.log('[' + i + '] rating=' + p.rating + '  ' + p.productName));",
              "const withRating = list.filter(p => p.rating !== null && p.rating !== undefined);",
              "pm.test('At least one stored product has a non-null rating', () => pm.expect(withRating.length, 'products with rating').to.be.above(0));"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/search/product/{{giftPlanId}}",
          "host": ["{{base_url}}"],
          "path": ["search", "product", "{{giftPlanId}}"]
        }
      }
    }
  ]
}
